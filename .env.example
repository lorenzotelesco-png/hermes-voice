# ── Piper TTS ─────────────────────────────────────────────────────
# Path to your Piper ONNX model file
PIPER_MODEL_PATH=models/it_IT/it_IT-paola-medium.onnx
# Path to the model config JSON
PIPER_MODEL_CONFIG=models/it_IT/it_IT-paola-medium.onnx.json

# ── Hermes Agent API ──────────────────────────────────────────────
# URL of the Hermes Agent OpenAI-compatible API (default: local port 8642)
HERMES_API_URL=http://127.0.0.1:8642/v1/chat/completions

# ── STT Language ──────────────────────────────────────────────────
# BCP-47 language code passed to Whisper (e.g. it, en, fr, de)
STT_LANGUAGE=it

# ── Discord Mirroring (optional) ──────────────────────────────────
# If both vars are set, each voice session is mirrored to a Discord thread.
# Leave blank to disable.
#
# 1. Create a webhook in your Discord channel:
#    Channel settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=

# 2. Bot token — the bot must be in the same server and have:
#    - Send Messages
#    - Create Public Threads
#    - Send Messages in Threads
DISCORD_BOT_TOKEN=

# ── Server ────────────────────────────────────────────────────────
PORT=5000
